# URL of the FastAPI backend (no trailing slash)
VITE_API_URL=http://localhost:8000

# Shopify storefront URL — used for "View Product" links on product cards
# In Shopify theme context set this to empty string (relative URLs work)
VITE_SHOPIFY_STORE_URL=https://your-store.myshopify.com

# Show "Powered by ShopAssist AI" footer in the chat widget
# Set to "false" to hide branding for merchants who prefer a white‑label widget
VITE_SHOW_BRANDING=true
