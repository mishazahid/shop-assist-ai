# ─────────────────────────────────────────────
# Shopify Admin API
# ─────────────────────────────────────────────
# Your store subdomain — no https://, no trailing slash
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API access token (starts with shpat_...)
SHOPIFY_ADMIN_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# API version
SHOPIFY_API_VERSION=2024-04

# Products per page (max 250)
SHOPIFY_PAGE_LIMIT=250

# ─────────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────────
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx

# Model to use for chat and intent extraction
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────
# App settings
# ─────────────────────────────────────────────
# Where to store products.csv and variants.csv (relative to backend/)
DATA_DIR=data

# ─────────────────────────────────────────────
# Webhooks (optional but recommended)
# ─────────────────────────────────────────────
# Public HTTPS URL of this backend — used to auto-register Shopify product
# webhooks on startup so the catalog stays in sync when products are
# added, updated, or deleted in Shopify.
# Example (Railway): https://shop-assist-ai-production.up.railway.app
PUBLIC_URL=https://your-public-backend-url.com
